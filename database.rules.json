{
  "rules": {
    "attendance": {
      ".indexOn": ["driverId", "clockIn", "clockOut"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "drivers": {
      ".indexOn": ["garageId", "bikeId", "deliveryCategoryIds"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "bikes": {
      ".indexOn": ["garageId", "driverId"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "garages": {
      ".indexOn": ["managerId"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "users": {
      ".indexOn": ["role", "garageId"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "deliveryCategories": {
      ".indexOn": ["priority"],
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "pushTokens": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "$other": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
